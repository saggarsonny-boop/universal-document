        "text": "Prescription — Maria Garcia"
      },
      {
        "type": "paragraph",
        "text": "Date: 24 April 2026"
      },
      {
        "type": "heading",
        "text": "Medication"
      },
      {
        "type": "paragraph",
        "text": "Amoxicillin 500mg capsules"
      },
      {
        "type": "paragraph",
        "text": "Dose: 1 capsule three times daily (every 8 hours)"
      },
      {
        "type": "paragraph",
        "text": "Duration: 7 days (21 capsules total)"
      },
      {
        "type": "paragraph",
        "text": "Route: Oral. Take with or after food."
      },
      {
        "type": "heading",
        "text": "Patient Instructions"
      },
      {
        "type": "paragraph",
        "text": "Complete the full course even if you feel better. Do not share this medication. If you develop a rash, swelling, or difficulty breathing, stop immediately and seek emergency care."
      },
      {
        "type": "heading",
        "text": "Prescriber"
      },
      {
        "type": "paragraph",
        "text": "Dr. J. Patel, MBChB MRCGP — Riverdale Medical Centre"
      },
      {
        "type": "paragraph",
        "text": "Prescriber Reference: GMC-7654321"
      }
    ]
  },
