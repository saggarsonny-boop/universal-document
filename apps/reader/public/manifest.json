{
  "name": "UD Reader",
  "short_name": "UD Reader",
  "description": "Open any Universal Document™ file — .uds, .udr, .udz",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#fafaf8",
  "theme_color": "#1e2d3d",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "/open",
      "accept": {
        "application/x-universal-document": [".uds", ".udr", ".udz"]
      }
    }
  ],
  "categories": ["productivity", "utilities"],
  "screenshots": []
}
